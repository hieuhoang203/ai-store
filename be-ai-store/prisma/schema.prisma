model MaGiamGia {
  id              String               @id @default(uuid()) @db.Uuid
  ma              String               @unique @db.VarChar(100)
  ten             String               @db.VarChar(255)
  moTa            String?              @map("mo_ta")
  loaiGiamGia     LoaiGiamGia          @map("loai_giam_gia")
  giaTriGiam      Decimal              @map("gia_tri_giam") @db.Decimal(18, 2)
  giamToiDa       Decimal?             @map("giam_toi_da") @db.Decimal(18, 2)
  donToiThieu     Decimal?             @map("don_toi_thieu") @db.Decimal(18, 2)
  gioiHanLuotDung Int?                 @map("gioi_han_luot_dung")
  soLuotDaDung    Int                  @default(0) @map("so_luot_da_dung")
  batDauLuc       DateTime?            @map("bat_dau_luc") @db.Timestamptz(6)
  ketThucLuc      DateTime?            @map("ket_thuc_luc") @db.Timestamptz(6)
  trangThai       TrangThaiChung       @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc          DateTime             @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc      DateTime             @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa           Boolean              @default(false) @map("da_xoa")
  goiDichVu       MaGiamGiaGoiDichVu[]
  nguoiDung       MaGiamGiaNguoiDung[]
  luotDung        LuotDungMaGiamGia[]
  donHang         DonHang[]

  @@index([ma], map: "idx_ma_giam_gia_ma")
  @@index([trangThai], map: "idx_ma_giam_gia_trang_thai")
  @@map("ma_giam_gia")
}

model MaGiamGiaGoiDichVu {
  id          String    @id @default(uuid()) @db.Uuid
  maGiamGiaId String    @map("ma_giam_gia_id") @db.Uuid
  goiDichVuId String    @map("goi_dich_vu_id") @db.Uuid
  taoLuc      DateTime  @default(now()) @map("tao_luc") @db.Timestamptz(6)
  maGiamGia   MaGiamGia @relation(fields: [maGiamGiaId], references: [id], onDelete: Cascade)
  goiDichVu   GoiDichVu @relation(fields: [goiDichVuId], references: [id], onDelete: Cascade)

  @@unique([maGiamGiaId, goiDichVuId], map: "uq_ma_giam_gia_goi")
  @@map("ma_giam_gia_goi_dich_vu")
}

model MaGiamGiaNguoiDung {
  id          String    @id @default(uuid()) @db.Uuid
  maGiamGiaId String    @map("ma_giam_gia_id") @db.Uuid
  nguoiDungId String    @map("nguoi_dung_id") @db.Uuid
  taoLuc      DateTime  @default(now()) @map("tao_luc") @db.Timestamptz(6)
  maGiamGia   MaGiamGia @relation(fields: [maGiamGiaId], references: [id], onDelete: Cascade)
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)

  @@unique([maGiamGiaId, nguoiDungId], map: "uq_ma_giam_gia_nguoi_dung")
  @@index([nguoiDungId], map: "idx_ma_giam_gia_nguoi_dung")
  @@map("ma_giam_gia_nguoi_dung")
}

model LuotDungMaGiamGia {
  id          String    @id @default(uuid()) @db.Uuid
  maGiamGiaId String    @map("ma_giam_gia_id") @db.Uuid
  nguoiDungId String    @map("nguoi_dung_id") @db.Uuid
  donHangId   String    @map("don_hang_id") @db.Uuid
  soTienGiam  Decimal   @map("so_tien_giam") @db.Decimal(18, 2)
  dungLuc     DateTime  @default(now()) @map("dung_luc") @db.Timestamptz(6)
  taoLuc      DateTime  @default(now()) @map("tao_luc") @db.Timestamptz(6)
  maGiamGia   MaGiamGia @relation(fields: [maGiamGiaId], references: [id])
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id])
  donHang     DonHang   @relation(fields: [donHangId], references: [id])

  @@unique([maGiamGiaId, donHangId], map: "uq_luot_dung_ma_don")
  @@index([nguoiDungId], map: "idx_luot_dung_ma_nguoi_dung")
  @@map("luot_dung_ma_giam_gia")
}

model DanhGia {
  id          String    @id @default(uuid()) @db.Uuid
