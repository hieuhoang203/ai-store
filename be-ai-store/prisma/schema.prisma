generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TrangThaiNguoiDung {
  CHUA_KICH_HOAT
  DANG_HOAT_DONG
  BI_KHOA
}

enum VaiTroHeThong {
  SUPER_ADMIN
  ADMIN
  HO_TRO
  KHACH_HANG
  NHA_CUNG_CAP
}

enum TrangThaiChung {
  DANG_HOAT_DONG
  TAM_TAT
  DA_XOA
}

enum KieuPhuongThucGiaoHang {
  GUI_LINK
  FORM_DOI_TAC
  GUI_EMAIL_CHO_DOI_TAC
  NHAP_TAY
}

enum TrangThaiTaiNguyen {
  SAN_SANG
  DA_GIU
  DA_BAN
  BI_KHOA
}

enum TrangThaiDonHang {
  CHO_THANH_TOAN
  DA_THANH_TOAN
  CHO_NHA_CUNG_CAP
  DANG_XU_LY
  DA_GIAO
  HOAN_THANH
  DA_HUY
}

enum TrangThaiThanhToan {
  CHO_THANH_TOAN
  DA_THANH_TOAN
  THAT_BAI
  DA_HOAN_TIEN
}

enum NhaCungCapTrangThai {
  CHO_KET_NOI
  DANG_HOAT_DONG
  TAM_KHOA
  NGUNG_HOP_TAC
}

enum TrangThaiLienKetNhaCungCap {
  CHUA_SU_DUNG
  DA_SU_DUNG
  HET_HAN
  DA_THU_HOI
}

enum TrangThaiYeuCauNhaCungCap {
  CHO_NHAN
  DA_NHAN
  DANG_XU_LY
  DA_TRA_KET_QUA
  THAT_BAI
  DA_HUY
}

enum TrangThaiGiaoHang {
  CHO_GIAO
  DA_GIAO
  THAT_BAI
}

enum LoaiNguonGiaoHang {
  KHO_NOI_BO
  NHA_CUNG_CAP
  ADMIN_NHAP_TAY
}

enum TrangThaiTicket {
  MOI
  DANG_XU_LY
  DA_GIAI_QUYET
  DA_DONG
}

enum LoaiThongBao {
  HE_THONG
  DON_HANG
  THANH_TOAN
  GIAO_HANG
  HO_TRO
  NHA_CUNG_CAP
}

enum LoaiGiamGia {
  PHAN_TRAM
  SO_TIEN
}

enum LoaiAudit {
  TAO
  CAP_NHAT
  XOA
  DANG_NHAP
  DANG_XUAT
  THANH_TOAN_WEBHOOK
  GIAO_HANG
  SUPPLIER_ONBOARD
  SUPPLIER_TRA_KET_QUA
  MA_GIAM_GIA
}

enum NhaCungCapKenhNhanViec {
  TELEGRAM_BOT
  TELEGRAM_MINI_APP
  LINK_FORM
  THU_CONG
}

model NguoiDung {
  id                 String               @id @default(uuid()) @db.Uuid
  telegramId         BigInt?              @unique @map("telegram_id") @db.BigInt
  username           String?              @db.VarChar(100)
  hoTen              String?              @map("ho_ten") @db.VarChar(255)
  soDienThoai        String?              @map("so_dien_thoai") @db.VarChar(20)
  email              String?              @db.VarChar(255)
  trangThai          TrangThaiNguoiDung   @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc             DateTime             @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc         DateTime             @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa              Boolean              @default(false) @map("da_xoa")
  vaiTro             NguoiDungVaiTro[]
  donHang            DonHang[]
  thongBao           ThongBao[]
  ticket             TicketHoTro[]
  danhGia            DanhGia[]
  maGiamGiaDuocGan   MaGiamGiaNguoiDung[]
  luotDungMaGiamGia  LuotDungMaGiamGia[]
  auditLogs          AuditLog[]           @relation("AuditNguoiThucHien")
  tokenDangNhapAdmin TokenDangNhapAdmin[]
  nhaCungCap         NhaCungCap?

  @@index([telegramId], map: "idx_nguoi_dung_telegram")
  @@index([trangThai], map: "idx_nguoi_dung_trang_thai")
  @@map("nguoi_dung")
}

model VaiTro {
  id         String            @id @default(uuid()) @db.Uuid
  ten        VaiTroHeThong     @unique @map("ten")
  taoLuc     DateTime          @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc DateTime          @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa      Boolean           @default(false) @map("da_xoa")
  nguoiDung  NguoiDungVaiTro[]

  @@map("vai_tro")
}

model NguoiDungVaiTro {
  id          String    @id @default(uuid()) @db.Uuid
  nguoiDungId String    @map("nguoi_dung_id") @db.Uuid
  vaiTroId    String    @map("vai_tro_id") @db.Uuid
  taoLuc      DateTime  @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc  DateTime  @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa       Boolean   @default(false) @map("da_xoa")
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)
  vaiTro      VaiTro    @relation(fields: [vaiTroId], references: [id], onDelete: Cascade)

  @@unique([nguoiDungId, vaiTroId], map: "uq_nguoi_dung_vai_tro")
  @@map("nguoi_dung_vai_tro")
}

model LoaiSanPham {
  id         String         @id @default(uuid()) @db.Uuid
  maLoai     String         @unique @map("ma_loai") @db.VarChar(80)
  tenLoai    String         @map("ten_loai") @db.VarChar(255)
  moTa       String?        @map("mo_ta")
  icon       String?        @db.VarChar(255)
  thuTu      Int            @default(0) @map("thu_tu")
  trangThai  TrangThaiChung @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc     DateTime       @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc DateTime       @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa      Boolean        @default(false) @map("da_xoa")
  sanPham    SanPham[]

  @@index([trangThai, daXoa], map: "idx_loai_san_pham_trang_thai")
  @@map("loai_san_pham")
}

model SanPham {
  id         String         @id @default(uuid()) @db.Uuid
  loaiId     String         @map("loai_id") @db.Uuid
  maSanPham  String         @unique @map("ma_san_pham") @db.VarChar(80)
  tenSanPham String         @map("ten_san_pham") @db.VarChar(255)
  moTa       String?        @map("mo_ta")
  anhDaiDien String?        @map("anh_dai_dien") @db.VarChar(500)
  thuTu      Int            @default(0) @map("thu_tu")
  trangThai  TrangThaiChung @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc     DateTime       @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc DateTime       @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa      Boolean        @default(false) @map("da_xoa")
  loai       LoaiSanPham    @relation(fields: [loaiId], references: [id])
  goiDichVu  GoiDichVu[]

  @@index([loaiId], map: "idx_san_pham_loai")
  @@index([trangThai, daXoa], map: "idx_san_pham_trang_thai")
  @@map("san_pham")
}

model GoiDichVu {
  id              String                  @id @default(uuid()) @db.Uuid
  sanPhamId       String                  @map("san_pham_id") @db.Uuid
  maGoi           String                  @unique @map("ma_goi") @db.VarChar(100)
  tenGoi          String                  @map("ten_goi") @db.VarChar(255)
  moTa            String?                 @map("mo_ta")
  thoiHanNgay     Int?                    @map("thoi_han_ngay")
  baoHanhNgay     Int?                    @map("bao_hanh_ngay")
  giaBan          Decimal                 @map("gia_ban") @db.Decimal(18, 2)
  giaVonDuKien    Decimal?                @map("gia_von_du_kien") @db.Decimal(18, 2)
  tonHienThi      Int                     @default(0) @map("ton_hien_thi")
  choPhepMua      Boolean                 @default(true) @map("cho_phep_mua")
  thuTu           Int                     @default(0) @map("thu_tu")
  trangThai       TrangThaiChung          @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc          DateTime                @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc      DateTime                @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa           Boolean                 @default(false) @map("da_xoa")
  sanPham         SanPham                 @relation(fields: [sanPhamId], references: [id])
  phuongThuc      GoiPhuongThucGiaoHang[]
  taiNguyen       TaiNguyenGiaoHang[]
  nhaCungCapGoi   NhaCungCapGoiDichVu[]
  chiTietDonHang  ChiTietDonHang[]
  maGiamGiaApDung MaGiamGiaGoiDichVu[]
  danhGia         DanhGia[]

  @@index([sanPhamId], map: "idx_goi_dich_vu_san_pham")
  @@index([choPhepMua, trangThai, daXoa], map: "idx_goi_dich_vu_mua")
  @@map("goi_dich_vu")
}

model PhuongThucGiaoHang {
  id             String                  @id @default(uuid()) @db.Uuid
  maPhuongThuc   String                  @unique @map("ma_phuong_thuc") @db.VarChar(80)
  tenPhuongThuc  String                  @map("ten_phuong_thuc") @db.VarChar(255)
  kieu           KieuPhuongThucGiaoHang  @map("kieu")
  moTa           String?                 @map("mo_ta")
  cauHinhMacDinh Json?                   @map("cau_hinh_mac_dinh")
  trangThai      TrangThaiChung          @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc         DateTime                @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc     DateTime                @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa          Boolean                 @default(false) @map("da_xoa")
  goiDichVu      GoiPhuongThucGiaoHang[]

  @@index([kieu], map: "idx_phuong_thuc_giao_hang_kieu")
  @@map("phuong_thuc_giao_hang")
}

model GoiPhuongThucGiaoHang {
  id                String                @id @default(uuid()) @db.Uuid
  goiDichVuId       String                @map("goi_dich_vu_id") @db.Uuid
  phuongThucId      String                @map("phuong_thuc_id") @db.Uuid
  uuTien            Int                   @default(0) @map("uu_tien")
  laMacDinh         Boolean               @default(false) @map("la_mac_dinh")
  tuDongGanSupplier Boolean               @default(false) @map("tu_dong_gan_supplier")
  cauHinh           Json?                 @map("cau_hinh")
  trangThai         TrangThaiChung        @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc            DateTime              @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc        DateTime              @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa             Boolean               @default(false) @map("da_xoa")
  goiDichVu         GoiDichVu             @relation(fields: [goiDichVuId], references: [id], onDelete: Cascade)
  phuongThuc        PhuongThucGiaoHang    @relation(fields: [phuongThucId], references: [id])
  taiNguyen         TaiNguyenGiaoHang[]
  nhaCungCapGoi     NhaCungCapGoiDichVu[]
  chiTietDonHang    ChiTietDonHang[]

  @@unique([goiDichVuId, phuongThucId], map: "uq_goi_phuong_thuc")
  @@index([goiDichVuId, laMacDinh], map: "idx_goi_phuong_thuc_mac_dinh")
  @@map("goi_phuong_thuc_giao_hang")
}

model NhaCungCap {
  id               String                 @id @default(uuid()) @db.Uuid
  nguoiDungId      String?                @unique @map("nguoi_dung_id") @db.Uuid
  telegramId       BigInt?                @unique @map("telegram_id") @db.BigInt
  usernameTelegram String?                @map("username_telegram") @db.VarChar(100)
  tenHienThi       String                 @map("ten_hien_thi") @db.VarChar(255)
  soDienThoai      String?                @map("so_dien_thoai") @db.VarChar(20)
  email            String?                @db.VarChar(255)
  ghiChu           String?                @map("ghi_chu")
  kenhNhanViec     NhaCungCapKenhNhanViec @default(TELEGRAM_BOT) @map("kenh_nhan_viec")
  trangThai        NhaCungCapTrangThai    @default(CHO_KET_NOI) @map("trang_thai")
  taoLuc           DateTime               @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc       DateTime               @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa            Boolean                @default(false) @map("da_xoa")
  nguoiDung        NguoiDung?             @relation(fields: [nguoiDungId], references: [id])
  lienKetMoi       LienKetNhaCungCap[]
  goiDichVu        NhaCungCapGoiDichVu[]
  yeuCau           YeuCauNhaCungCap[]

  @@index([telegramId], map: "idx_nha_cung_cap_telegram")
  @@index([trangThai], map: "idx_nha_cung_cap_trang_thai")
  @@map("nha_cung_cap")
}

model LienKetNhaCungCap {
  id              String                     @id @default(uuid()) @db.Uuid
  nhaCungCapId    String?                    @map("nha_cung_cap_id") @db.Uuid
  maToken         String                     @unique @map("ma_token") @db.VarChar(120)
  tenMoi          String?                    @map("ten_moi") @db.VarChar(255)
  ghiChu          String?                    @map("ghi_chu")
  telegramIdDaGan BigInt?                    @map("telegram_id_da_gan") @db.BigInt
  hetHanLuc       DateTime?                  @map("het_han_luc") @db.Timestamptz(6)
  dungLuc         DateTime?                  @map("dung_luc") @db.Timestamptz(6)
  trangThai       TrangThaiLienKetNhaCungCap @default(CHUA_SU_DUNG) @map("trang_thai")
  taoLuc          DateTime                   @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc      DateTime                   @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  nhaCungCap      NhaCungCap?                @relation(fields: [nhaCungCapId], references: [id])

  @@index([trangThai, hetHanLuc], map: "idx_lien_ket_ncc_trang_thai")
  @@map("lien_ket_nha_cung_cap")
}

model NhaCungCapGoiDichVu {
  id               String                @id @default(uuid()) @db.Uuid
  nhaCungCapId     String                @map("nha_cung_cap_id") @db.Uuid
  goiDichVuId      String                @map("goi_dich_vu_id") @db.Uuid
  goiPhuongThucId  String                @map("goi_phuong_thuc_id") @db.Uuid
  giaVon           Decimal?              @map("gia_von") @db.Decimal(18, 2)
  soLuongCoTheNhan Int?                  @map("so_luong_co_the_nhan")
  soLuongDangGiu   Int                   @default(0) @map("so_luong_dang_giu")
  thoiGianXuLyPhut Int?                  @map("thoi_gian_xu_ly_phut")
  tyLeThanhCong    Decimal?              @map("ty_le_thanh_cong") @db.Decimal(5, 2)
  uuTien           Int                   @default(0) @map("uu_tien")
  cauHinh          Json?                 @map("cau_hinh")
  trangThai        TrangThaiChung        @default(DANG_HOAT_DONG) @map("trang_thai")
  taoLuc           DateTime              @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc       DateTime              @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa            Boolean               @default(false) @map("da_xoa")
  nhaCungCap       NhaCungCap            @relation(fields: [nhaCungCapId], references: [id])
  goiDichVu        GoiDichVu             @relation(fields: [goiDichVuId], references: [id])
  goiPhuongThuc    GoiPhuongThucGiaoHang @relation(fields: [goiPhuongThucId], references: [id])

  @@unique([nhaCungCapId, goiDichVuId, goiPhuongThucId], map: "uq_ncc_goi_phuong_thuc")
  @@index([goiDichVuId, trangThai], map: "idx_ncc_goi_dich_vu")
  @@map("nha_cung_cap_goi_dich_vu")
}

model TaiNguyenGiaoHang {
  id                String                @id @default(uuid()) @db.Uuid
  goiDichVuId       String                @map("goi_dich_vu_id") @db.Uuid
  goiPhuongThucId   String                @map("goi_phuong_thuc_id") @db.Uuid
  maTaiNguyen       String?               @map("ma_tai_nguyen") @db.VarChar(120)
  duLieuMaHoa       String?               @map("du_lieu_ma_hoa")
  duLieuCongKhai    Json?                 @map("du_lieu_cong_khai")
  soLanDungToiDa    Int?                  @map("so_lan_dung_toi_da")
  soLanDaDung       Int                   @default(0) @map("so_lan_da_dung")
  giuChoDonHangId   String?               @map("giu_cho_don_hang_id") @db.Uuid
  giuChoNguoiDungId String?               @map("giu_cho_nguoi_dung_id") @db.Uuid
  giuDenLuc         DateTime?             @map("giu_den_luc") @db.Timestamptz(6)
  banLuc            DateTime?             @map("ban_luc") @db.Timestamptz(6)
  trangThai         TrangThaiTaiNguyen    @default(SAN_SANG) @map("trang_thai")
  taoLuc            DateTime              @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc        DateTime              @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa             Boolean               @default(false) @map("da_xoa")
  goiDichVu         GoiDichVu             @relation(fields: [goiDichVuId], references: [id])
  goiPhuongThuc     GoiPhuongThucGiaoHang @relation(fields: [goiPhuongThucId], references: [id])
  giaoHang          GiaoHang[]

  @@index([goiDichVuId, trangThai], map: "idx_tai_nguyen_goi_trang_thai")
  @@index([giuChoDonHangId], map: "idx_tai_nguyen_don_giu")
  @@map("tai_nguyen_giao_hang")
}

model DonHang {
  id                 String              @id @default(uuid()) @db.Uuid
  maDonHang          String              @unique @map("ma_don_hang") @db.VarChar(60)
  nguoiDungId        String              @map("nguoi_dung_id") @db.Uuid
  tamTinh            Decimal             @default(0) @map("tam_tinh") @db.Decimal(18, 2)
  giamGia            Decimal             @default(0) @map("giam_gia") @db.Decimal(18, 2)
  tongTien           Decimal             @default(0) @map("tong_tien") @db.Decimal(18, 2)
  maGiamGiaId        String?             @map("ma_giam_gia_id") @db.Uuid
  trangThai          TrangThaiDonHang    @default(CHO_THANH_TOAN) @map("trang_thai")
  trangThaiThanhToan TrangThaiThanhToan  @default(CHO_THANH_TOAN) @map("trang_thai_thanh_toan")
  taoLuc             DateTime            @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc         DateTime            @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa              Boolean             @default(false) @map("da_xoa")
  nguoiDung          NguoiDung           @relation(fields: [nguoiDungId], references: [id])
  maGiamGia          MaGiamGia?          @relation(fields: [maGiamGiaId], references: [id])
  chiTiet            ChiTietDonHang[]
  thanhToan          ThanhToan[]
  ticket             TicketHoTro[]
  danhGia            DanhGia[]
  luotDungMaGiamGia  LuotDungMaGiamGia[]

  @@index([nguoiDungId], map: "idx_don_hang_nguoi_dung")
  @@index([trangThai], map: "idx_don_hang_trang_thai")
  @@index([trangThaiThanhToan], map: "idx_don_hang_thanh_toan")
  @@map("don_hang")
}

model ChiTietDonHang {
  id               String                @id @default(uuid()) @db.Uuid
  donHangId        String                @map("don_hang_id") @db.Uuid
  goiDichVuId      String                @map("goi_dich_vu_id") @db.Uuid
  goiPhuongThucId  String                @map("goi_phuong_thuc_id") @db.Uuid
  soLuong          Int                   @default(1) @map("so_luong")
  donGia           Decimal               @map("don_gia") @db.Decimal(18, 2)
  thanhTien        Decimal               @map("thanh_tien") @db.Decimal(18, 2)
  duLieuKhachNhap  Json?                 @map("du_lieu_khach_nhap")
  taoLuc           DateTime              @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc       DateTime              @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa            Boolean               @default(false) @map("da_xoa")
  donHang          DonHang               @relation(fields: [donHangId], references: [id], onDelete: Cascade)
  goiDichVu        GoiDichVu             @relation(fields: [goiDichVuId], references: [id])
  goiPhuongThuc    GoiPhuongThucGiaoHang @relation(fields: [goiPhuongThucId], references: [id])
  yeuCauNhaCungCap YeuCauNhaCungCap[]
  giaoHang         GiaoHang[]

  @@index([donHangId], map: "idx_chi_tiet_don_hang_don")
  @@index([goiDichVuId], map: "idx_chi_tiet_don_hang_goi")
  @@map("chi_tiet_don_hang")
}

model ThanhToan {
  id                  String             @id @default(uuid()) @db.Uuid
  donHangId           String             @map("don_hang_id") @db.Uuid
  nhaCungCapThanhToan String             @default("PAYOS") @map("nha_cung_cap_thanh_toan") @db.VarChar(50)
  soTien              Decimal            @map("so_tien") @db.Decimal(18, 2)
  maGiaoDich          String?            @map("ma_giao_dich") @db.VarChar(255)
  noiDungThanhToan    String?            @map("noi_dung_thanh_toan") @db.VarChar(255)
  duLieuQr            Json?              @map("du_lieu_qr")
  trangThai           TrangThaiThanhToan @default(CHO_THANH_TOAN) @map("trang_thai")
  thanhToanLuc        DateTime?          @map("thanh_toan_luc") @db.Timestamptz(6)
  taoLuc              DateTime           @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc          DateTime           @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa               Boolean            @default(false) @map("da_xoa")
  donHang             DonHang            @relation(fields: [donHangId], references: [id])

  @@index([donHangId], map: "idx_thanh_toan_don_hang")
  @@index([trangThai], map: "idx_thanh_toan_trang_thai")
  @@map("thanh_toan")
}

model YeuCauNhaCungCap {
