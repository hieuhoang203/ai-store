model AuditLog {
  id              String     @id @default(uuid()) @db.Uuid
  nguoiThucHienId String?    @map("nguoi_thuc_hien_id") @db.Uuid
  tenBang         String     @map("ten_bang") @db.VarChar(120)
  banGhiId        String?    @map("ban_ghi_id") @db.Uuid
  hanhDong        LoaiAudit  @map("hanh_dong")
  duLieuCu        Json?      @map("du_lieu_cu")
  duLieuMoi       Json?      @map("du_lieu_moi")
  ip              String?    @db.VarChar(64)
  userAgent       String?    @map("user_agent") @db.VarChar(500)
  taoLuc          DateTime   @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc      DateTime   @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  daXoa           Boolean    @default(false) @map("da_xoa")
  nguoiThucHien   NguoiDung? @relation("AuditNguoiThucHien", fields: [nguoiThucHienId], references: [id])

  @@index([nguoiThucHienId], map: "idx_audit_nguoi_thuc_hien")
  @@index([tenBang, banGhiId], map: "idx_audit_ban_ghi")
  @@index([taoLuc(sort: Desc)], map: "idx_audit_tao_luc")
  @@map("audit_log")
}
