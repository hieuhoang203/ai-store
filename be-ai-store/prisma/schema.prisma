generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  INACTIVE
  ACTIVE
  LOCKED
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  CUSTOMER
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
  LOCKED
}

enum DeliveryMethod {
  ACCOUNT
  EMAIL_INVITE
  LINK_INVITE
  LICENSE_KEY
  API_KEY
  VOUCHER_CODE
  MANUAL
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  WAITING_SUPPLIER
  FULFILLING
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}

enum SupplierRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  SYSTEM
  ORDER
  PAYMENT
  DELIVERY
  SUPPORT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT_WEBHOOK
  DELIVERY_SENT
  COUPON_CREATE
  COUPON_UPDATE
  COUPON_DELETE
  COUPON_DISABLE
  REVIEW_HIDE
  REVIEW_SHOW
}

enum PaymentProvider {
  BANKING_QR
  MOMO
  ZALOPAY
  VNPAY
}

enum DiscountType {
  PERCENT
  FIXED
}

enum AdminLoginTokenStatus {
  PENDING
  USED
  EXPIRED
  REVOKED
}

enum ActivityLogType {
  COUPON_APPLIED
  REVIEW_CREATED
  REVIEW_UPDATED
}

model User {
  id                  String            @id @default(uuid()) @db.Uuid
  telegramId          BigInt?           @unique @map("telegram_id") @db.BigInt
  username            String?           @db.VarChar(100)
  fullName            String?           @map("full_name") @db.VarChar(255)
  phone               String?           @db.VarChar(20)
  email               String?           @db.VarChar(255)
  status              UserStatus        @default(ACTIVE)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted           Boolean           @default(false) @map("is_deleted")
  roles               UserRole[]
  reservedInventories Inventory[]       @relation("InventoryReservedBy")
  orders              Order[]
  tickets             Ticket[]
  notifications       Notification[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]        @relation("AuditActor")
  adminLoginTokens    AdminLoginToken[]
  couponsCreated      Coupon[]
  couponUsers         CouponUser[]
  couponUsages        CouponUsage[]
  reviews             Review[]
  activityLogs        ActivityLog[]

  @@index([telegramId], map: "idx_users_telegram")
  @@index([status], map: "idx_users_status")
  @@index([createdAt(sort: Desc)], map: "idx_users_created_at")
  @@map("users")
}

model Role {
  id        String     @id @default(uuid()) @db.Uuid
  name      RoleName   @unique
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean    @default(false) @map("is_deleted")
  users     UserRole[]

  @@map("roles")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  icon      String?   @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean   @default(false) @map("is_deleted")
  products  Product[]

  @@index([name], map: "idx_categories_name")
  @@index([isDeleted], map: "idx_categories_deleted")
  @@map("categories")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean  @default(false) @map("is_deleted")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uq_user_roles_user_role")
  @@index([roleId], map: "idx_user_roles_role")
  @@map("user_roles")
}

model Product {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(50)
  name        String           @db.VarChar(255)
  description String?
  categoryId  String?          @map("category_id") @db.Uuid
  imageUrl    String?          @map("image_url") @db.VarChar(500)
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted   Boolean          @default(false) @map("is_deleted")
  categoryRef Category?        @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]

  @@index([categoryId], map: "idx_products_category_id")
  @@index([isActive, isDeleted], map: "idx_products_active_deleted")
  @@index([createdAt(sort: Desc)], map: "idx_products_created_at")
  @@map("products")
}

model ProductVariant {
  id             String          @id @default(uuid()) @db.Uuid
  productId      String          @map("product_id") @db.Uuid
  name           String          @db.VarChar(255)
  durationDays   Int?            @map("duration_days")
  sellPrice      Decimal         @map("sell_price") @db.Decimal(18, 2)
  deliveryMethod DeliveryMethod  @default(ACCOUNT) @map("delivery_method")
  displayStock   Int             @default(0) @map("display_stock")
  warrantyDays   Int?            @map("warranty_days")
  active         Boolean         @default(true)
  averageRating  Decimal         @default(0) @map("average_rating") @db.Decimal(3, 2)
  reviewCount    Int             @default(0) @map("review_count")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted      Boolean         @default(false) @map("is_deleted")
  product        Product         @relation(fields: [productId], references: [id])
  inventories    Inventory[]
  supplierVariants SupplierVariant[]
  orderItems     OrderItem[]
  couponProducts CouponProduct[]
  reviews        Review[]

  @@index([productId], map: "idx_product_variants_product")
  @@index([active, isDeleted], map: "idx_product_variants_active_deleted")
  @@map("product_variants")
}

model Supplier {
  id                 String            @id @default(uuid()) @db.Uuid
  name               String            @db.VarChar(255)
  email              String?           @db.VarChar(255)
  telegram           String?           @db.VarChar(100)
  zalo               String?           @db.VarChar(50)
  active             Boolean           @default(true)
  avgDeliveryMinutes Int?              @map("avg_delivery_minutes")
  successRate        Decimal?          @map("success_rate") @db.Decimal(5, 2)
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  variants           SupplierVariant[]
  requests           SupplierRequest[]

  @@index([active], map: "idx_suppliers_active")
  @@map("suppliers")
}

model SupplierVariant {
  id                String         @id @default(uuid()) @db.Uuid
  supplierId        String         @map("supplier_id") @db.Uuid
  variantId         String         @map("variant_id") @db.Uuid
  costPrice         Decimal        @map("cost_price") @db.Decimal(18, 2)
  availableQuantity Int            @default(0) @map("available_quantity")
  reservedQuantity  Int            @default(0) @map("reserved_quantity")
  soldQuantity      Int            @default(0) @map("sold_quantity")
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  supplier          Supplier       @relation(fields: [supplierId], references: [id])
  variant           ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([supplierId, variantId], map: "uq_supplier_variants_supplier_variant")
  @@index([variantId], map: "idx_supplier_variants_variant")
  @@index([active], map: "idx_supplier_variants_active")
  @@map("supplier_variants")
}

model SupplierRequest {
  id          String                @id @default(uuid()) @db.Uuid
  orderId     String                @map("order_id") @db.Uuid
  supplierId  String                @map("supplier_id") @db.Uuid
  status      SupplierRequestStatus @default(PENDING)
  note        String?
  requestedAt DateTime              @default(now()) @map("requested_at") @db.Timestamptz(6)
  fulfilledAt DateTime?             @map("fulfilled_at") @db.Timestamptz(6)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  order       Order                 @relation(fields: [orderId], references: [id])
  supplier    Supplier              @relation(fields: [supplierId], references: [id])
  items       SupplierRequestItem[]

  @@index([orderId], map: "idx_supplier_requests_order")
  @@index([supplierId], map: "idx_supplier_requests_supplier")
  @@index([status], map: "idx_supplier_requests_status")
  @@map("supplier_requests")
}

model SupplierRequestItem {
  id          String          @id @default(uuid()) @db.Uuid
  requestId   String          @map("request_id") @db.Uuid
  orderItemId String          @map("order_item_id") @db.Uuid
  quantity    Int
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  request     SupplierRequest @relation(fields: [requestId], references: [id])
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id])

  @@index([requestId], map: "idx_supplier_request_items_request")
  @@index([orderItemId], map: "idx_supplier_request_items_order_item")
  @@map("supplier_request_items")
}

model Inventory {
  id                String          @id @default(uuid()) @db.Uuid
  variantId         String          @map("variant_id") @db.Uuid
  accountEmail      String?         @map("account_email") @db.VarChar(255)
  encryptedPassword String?         @map("encrypted_password")
  metadata          Json?
  status            InventoryStatus @default(AVAILABLE)
  reservedBy        String?         @map("reserved_by") @db.Uuid
  reservedAt        DateTime?       @map("reserved_at") @db.Timestamptz(6)
  reservedUntil     DateTime?       @map("reserved_until") @db.Timestamptz(6)
  reservedOrderId   String?         @map("reserved_order_id") @db.Uuid
  deliveredAt       DateTime?       @map("delivered_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted         Boolean         @default(false) @map("is_deleted")
  variant           ProductVariant  @relation(fields: [variantId], references: [id])
  reserver          User?           @relation("InventoryReservedBy", fields: [reservedBy], references: [id])
  orderItems        OrderItem[]
  deliveries        Delivery[]

  @@index([variantId], map: "idx_inventory_variant")
  @@index([status], map: "idx_inventory_status")
  @@index([reservedBy], map: "idx_inventory_reserved_by")
  @@index([reservedOrderId], map: "idx_inventory_reserved_order")
  @@index([status, reservedUntil], map: "idx_inventory_status_reserved_until")
  @@map("inventories")
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  orderNo       String        @unique @map("order_no") @db.VarChar(50)
  userId        String        @map("user_id") @db.Uuid
  subtotal      Decimal       @default(0) @db.Decimal(18, 2)
  discount      Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount   Decimal       @default(0) @map("total_amount") @db.Decimal(18, 2)
  couponId      String?       @map("coupon_id") @db.Uuid
  status        OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted     Boolean       @default(false) @map("is_deleted")
  user          User          @relation(fields: [userId], references: [id])
  coupon        Coupon?       @relation(fields: [couponId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  tickets       Ticket[]
  couponUsages  CouponUsage[]
  reviews       Review[]
  supplierRequests SupplierRequest[]

  @@index([userId], map: "idx_orders_user")
  @@index([couponId], map: "idx_orders_coupon")
  @@index([status], map: "idx_orders_status")
  @@index([paymentStatus], map: "idx_orders_payment_status")
  @@index([createdAt(sort: Desc)], map: "idx_orders_created")
  @@map("orders")
}

model Coupon {
  id             String          @id @default(uuid()) @db.Uuid
  code           String          @unique @db.VarChar(100)
  name           String          @db.VarChar(255)
  description    String?
  discountType   DiscountType    @map("discount_type")
  discountValue  Decimal         @map("discount_value") @db.Decimal(18, 2)
  maxDiscount    Decimal?        @map("max_discount") @db.Decimal(18, 2)
  minOrderAmount Decimal?        @map("min_order_amount") @db.Decimal(18, 2)
  usageLimit     Int?            @map("usage_limit")
  usedCount      Int             @default(0) @map("used_count")
  startsAt       DateTime?       @map("starts_at") @db.Timestamptz(6)
  endsAt         DateTime?       @map("ends_at") @db.Timestamptz(6)
  isActive       Boolean         @default(true) @map("is_active")
  createdBy      String?         @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted      Boolean         @default(false) @map("is_deleted")
  creator        User?           @relation(fields: [createdBy], references: [id])
  products       CouponProduct[]
  users          CouponUser[]
  usages         CouponUsage[]
  orders         Order[]

  @@index([code], map: "idx_coupons_code")
  @@index([isActive], map: "idx_coupons_active")
  @@index([startsAt], map: "idx_coupons_starts")
  @@index([endsAt], map: "idx_coupons_ends")
  @@map("coupons")
}

model CouponProduct {
  id               String         @id @default(uuid()) @db.Uuid
  couponId         String         @map("coupon_id") @db.Uuid
  productVariantId String         @map("product_variant_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted        Boolean        @default(false) @map("is_deleted")
  coupon           Coupon         @relation(fields: [couponId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([couponId, productVariantId], map: "uq_coupon_products_coupon_variant")
  @@index([couponId], map: "idx_coupon_products_coupon")
  @@index([productVariantId], map: "idx_coupon_products_variant")
  @@map("coupon_products")
}

model CouponUser {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean  @default(false) @map("is_deleted")
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId], map: "uq_coupon_users_coupon_user")
  @@index([couponId], map: "idx_coupon_users_coupon")
  @@index([userId], map: "idx_coupon_users_user")
  @@map("coupon_users")
}

model CouponUsage {
  id             String   @id @default(uuid()) @db.Uuid
  couponId       String   @map("coupon_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  discountAmount Decimal  @map("discount_amount") @db.Decimal(18, 2)
  usedAt         DateTime @default(now()) @map("used_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted      Boolean  @default(false) @map("is_deleted")
  coupon         Coupon   @relation(fields: [couponId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  order          Order    @relation(fields: [orderId], references: [id])

  @@unique([couponId, orderId], map: "uq_coupon_usages_coupon_order")
  @@index([couponId], map: "idx_coupon_usages_coupon")
  @@index([userId], map: "idx_coupon_usages_user")
  @@index([orderId], map: "idx_coupon_usages_order")
  @@map("coupon_usages")
}

model OrderItem {
  id          String         @id @default(uuid()) @db.Uuid
  orderId     String         @map("order_id") @db.Uuid
  variantId   String         @map("variant_id") @db.Uuid
  inventoryId String?        @map("inventory_id") @db.Uuid
  quantity    Int            @default(1)
  unitPrice   Decimal        @map("unit_price") @db.Decimal(18, 2)
  totalPrice  Decimal        @map("total_price") @db.Decimal(18, 2)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted   Boolean        @default(false) @map("is_deleted")
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  inventory   Inventory?     @relation(fields: [inventoryId], references: [id])
  deliveries  Delivery[]
  fulfillments Fulfillment[]
  supplierRequestItems SupplierRequestItem[]

  @@index([orderId], map: "idx_order_items_order")
  @@index([variantId], map: "idx_order_items_variant")
  @@index([inventoryId], map: "idx_order_items_inventory")
  @@map("order_items")
}

model Fulfillment {
  id          String              @id @default(uuid()) @db.Uuid
  orderItemId String              @map("order_item_id") @db.Uuid
  status      FulfillmentStatus   @default(PENDING)
  deliveredAt DateTime?           @map("delivered_at") @db.Timestamptz(6)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  orderItem   OrderItem           @relation(fields: [orderItemId], references: [id])
  resources   FulfillmentResource[]

  @@index([orderItemId], map: "idx_fulfillments_order_item")
  @@index([status], map: "idx_fulfillments_status")
  @@map("fulfillments")
}

model FulfillmentResource {
  id            String         @id @default(uuid()) @db.Uuid
  fulfillmentId String         @map("fulfillment_id") @db.Uuid
  type          DeliveryMethod
  payload       Json
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  fulfillment   Fulfillment    @relation(fields: [fulfillmentId], references: [id])

  @@index([fulfillmentId], map: "idx_fulfillment_resources_fulfillment")
  @@index([type], map: "idx_fulfillment_resources_type")
  @@map("fulfillment_resources")
}

model Payment {
  id             String          @id @default(uuid()) @db.Uuid
  orderId        String          @map("order_id") @db.Uuid
  provider       PaymentProvider @default(BANKING_QR)
  amount         Decimal         @db.Decimal(18, 2)
  transactionNo  String?         @map("transaction_no") @db.VarChar(255)
  paymentContent String?         @map("payment_content") @db.VarChar(255)
  qrContent      String?         @map("qr_content")
  status         PaymentStatus   @default(PENDING)
  paidAt         DateTime?       @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted      Boolean         @default(false) @map("is_deleted")
  order          Order           @relation(fields: [orderId], references: [id])

  @@index([orderId], map: "idx_payment_order")
  @@index([status], map: "idx_payments_status")
  @@index([provider], map: "idx_payments_provider")
  @@map("payments")
}

model Delivery {
  id              String         @id @default(uuid()) @db.Uuid
  orderItemId     String         @map("order_item_id") @db.Uuid
  inventoryId     String         @map("inventory_id") @db.Uuid
  deliveryContent String?        @map("delivery_content")
  metadata        Json?
  deliveredAt     DateTime?      @map("delivered_at") @db.Timestamptz(6)
  status          DeliveryStatus @default(PENDING)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted       Boolean        @default(false) @map("is_deleted")
  orderItem       OrderItem      @relation(fields: [orderItemId], references: [id])
  inventory       Inventory      @relation(fields: [inventoryId], references: [id])

  @@index([orderItemId], map: "idx_deliveries_order_item")
  @@index([inventoryId], map: "idx_deliveries_inventory")
  @@index([status], map: "idx_deliveries_status")
  @@map("deliveries")
}

model Ticket {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  orderId   String?      @map("order_id") @db.Uuid
  subject   String       @db.VarChar(255)
  content   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean      @default(false) @map("is_deleted")
  user      User         @relation(fields: [userId], references: [id])
  order     Order?       @relation(fields: [orderId], references: [id])

  @@index([userId], map: "idx_tickets_user")
  @@index([orderId], map: "idx_tickets_order")
  @@index([status], map: "idx_tickets_status")
  @@map("tickets")
}

model Review {
  id               String         @id @default(uuid()) @db.Uuid
  orderId          String         @map("order_id") @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  productVariantId String         @map("product_variant_id") @db.Uuid
  rating           Int
  comment          String?
  isHidden         Boolean        @default(false) @map("is_hidden")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted        Boolean        @default(false) @map("is_deleted")
  order            Order          @relation(fields: [orderId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([orderId, productVariantId], map: "uq_reviews_order_variant")
  @@index([userId], map: "idx_reviews_user")
  @@index([productVariantId], map: "idx_reviews_variant")
  @@index([rating], map: "idx_reviews_rating")
  @@index([isHidden], map: "idx_reviews_hidden")
  @@map("reviews")
}

model ActivityLog {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String?         @map("user_id") @db.Uuid
  type       ActivityLogType
  entityName String          @map("entity_name") @db.VarChar(100)
  entityId   String?         @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted  Boolean         @default(false) @map("is_deleted")
  user       User?           @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_activity_logs_user")
  @@index([type], map: "idx_activity_logs_type")
  @@index([entityName, entityId], map: "idx_activity_logs_entity")
  @@index([createdAt(sort: Desc)], map: "idx_activity_logs_created")
  @@map("activity_logs")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType @default(SYSTEM)
  title     String           @db.VarChar(255)
  content   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean          @default(false) @map("is_deleted")
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_notification_user")
  @@index([isRead], map: "idx_notifications_read")
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiredAt DateTime @map("expired_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean  @default(false) @map("is_deleted")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user")
  @@index([expiredAt], map: "idx_refresh_tokens_expired_at")
  @@map("refresh_tokens")
}

model AdminLoginToken {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @map("user_id") @db.Uuid
  tokenHash String                @unique @map("token_hash")
  status    AdminLoginTokenStatus @default(PENDING)
  expiredAt DateTime              @map("expired_at") @db.Timestamptz(6)
  usedAt    DateTime?             @map("used_at") @db.Timestamptz(6)
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted Boolean               @default(false) @map("is_deleted")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_admin_login_tokens_user")
  @@index([status, expiredAt], map: "idx_admin_login_tokens_status_expired")
  @@map("admin_login_tokens")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  entityName String      @map("entity_name") @db.VarChar(100)
  entityId   String?     @map("entity_id") @db.Uuid
  action     AuditAction
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  ipAddress  String?     @map("ip_address") @db.VarChar(64)
  userAgent  String?     @map("user_agent") @db.VarChar(500)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted  Boolean     @default(false) @map("is_deleted")
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId], map: "idx_audit_logs_actor")
  @@index([entityName, entityId], map: "idx_audit_logs_entity")
  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}
