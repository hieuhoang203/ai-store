  nhaCungCapId     String                    @map("nha_cung_cap_id") @db.Uuid
  maYeuCau         String                    @unique @map("ma_yeu_cau") @db.VarChar(80)
  soLuong          Int                       @default(1) @map("so_luong")
  duLieuGui        Json?                     @map("du_lieu_gui")
  duLieuPhanHoi    Json?                     @map("du_lieu_phan_hoi")
  tokenForm        String?                   @unique @map("token_form") @db.VarChar(120)
  guiLuc           DateTime?                 @map("gui_luc") @db.Timestamptz(6)
  nhanLuc          DateTime?                 @map("nhan_luc") @db.Timestamptz(6)
  traKetQuaLuc     DateTime?                 @map("tra_ket_qua_luc") @db.Timestamptz(6)
  trangThai        TrangThaiYeuCauNhaCungCap @default(CHO_NHAN) @map("trang_thai")
  ghiChu           String?                   @map("ghi_chu")
  taoLuc           DateTime                  @default(now()) @map("tao_luc") @db.Timestamptz(6)
  capNhatLuc       DateTime                  @default(now()) @updatedAt @map("cap_nhat_luc") @db.Timestamptz(6)
  chiTietDonHang   ChiTietDonHang            @relation(fields: [chiTietDonHangId], references: [id])
  nhaCungCap       NhaCungCap                @relation(fields: [nhaCungCapId], references: [id])
